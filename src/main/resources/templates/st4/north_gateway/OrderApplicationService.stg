// 模板组
OrderApplicationServiceTemplate(data) ::= <<
package <data.packagePath>;

import <data.groupId>.aggregate.OrderAggregate;
import <data.groupId>.order.dto.req.CreateOrderRequest;
import <data.groupId>.order.dto.resp.OrderResponse;

/**
 * 订单应用服务接口
 *
 * @author ZhangZhiHong
 */
public interface OrderApplicationService {

    /**
     * 创建订单
     */
    OrderResponse createOrder(CreateOrderRequest request);

    OrderAggregate getOrder(String orderIdStr);
}
>>